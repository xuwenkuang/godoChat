}
localized_background = {
"en": "Lived in this village for 60 years, witnessed its rise and fall. Was once an adventurer in youth, now dedicated to protecting the village's peace.",
"zh": "在这个村庄生活了60年，见证了村庄的兴衰。年轻时曾是一名冒险者，现在致力于保护村庄的安宁。"
}
